# Скопируй в .env (он в .gitignore) и заполни. Токены НЕ коммитить.
# Старые токены были в коде/чате → СКОМПРОМЕТИРОВАНЫ, перевыпусти у @BotFather.

# Токен пульсового бота @HRV_monitor_bot
HRV_BOT_TOKEN=

# Токен комбо-бота @assessment_center_analyzer_bot
COMBO_BOT_TOKEN=

# Writable runtime-хранилище. На сервере Dropbox read-only — указать сюда writable путь,
# напр. /home/node/openclaw-vault/combo . Локально можно не задавать (пишет рядом с кодом).
# COMBO_RUNTIME_DIR=/home/node/openclaw-vault/combo
# HRV_DATA_DIR=/home/node/openclaw-vault/hrv/data
# HRV_EXPORTS_DIR=/home/node/openclaw-vault/hrv/exports

# Каталог, который отдаёт webapp (combo_data.json). По умолчанию NEW VERSION/webapp.
# COMBO_WEBAPP_DIR=/home/node/openclaw-vault/webapp

# Интерпретеры venv (если venv не рядом с кодом)
# COMBO_MAIN_PYTHON=/path/to/venv_new/bin/python
# COMBO_EMO_PYTHON=/path/to/emo_venv/bin/python
